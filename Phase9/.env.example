# Phase 9 — Render backend deployment
# Copy to Render dashboard or symlink to repo root as render.yaml

# Phase 7 (gateway)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
PHASE7_API_KEYS=phase7-demo-key:user,phase7-admin-key:user,admin
CORS_ORIGINS=http://localhost:8082,https://your-app.vercel.app

# Phase 8 (personalization) — set PHASE7_BASE to Phase 7 Render URL after first deploy
PHASE7_BASE=https://rrs-phase7.onrender.com
PHASE8_DEFAULT_KEY=phase7-demo-key
PHASE8_DATASET=/opt/render/project/src/Phase1/outputs/restaurants_clean.csv
# CORS_ORIGINS same as above for Vercel frontend (Phase 10)
